---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageCarousel from '../../components/ImageCarousel.astro';
import ShareLinks from '../../components/ShareLinks.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <article class="px-8 sm:px-12 py-10">

    <!-- Back link -->
    <div class="mb-6">
      <a href="/projects" class="text-xs text-muted hover:text-subtle transition-colors duration-150">
        ← Projects
      </a>
    </div>

    <!-- Two-column: Carousel + Sidebar -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

      <!-- Left: Carousel -->
      <div class="lg:col-span-3">
        {project.data.images && project.data.images.length > 0 ? (
          <ImageCarousel images={project.data.images} />
        ) : (
          <div class="aspect-[16/10] bg-tag-bg rounded-xl overflow-hidden">
            <img
              src={project.data.coverImage}
              alt={project.data.title}
              class="w-full h-full object-cover"
            />
          </div>
        )}
      </div>

      <!-- Right: Metadata sidebar -->
      <div class="lg:col-span-2 space-y-6">
        <h1 class="text-2xl font-bold text-heading tracking-tight">
          {project.data.title}
        </h1>

        <!-- Year -->
        <div>
          <span class="text-xs font-semibold text-muted uppercase tracking-wider">Year</span>
          <p class="text-sm text-heading mt-1">{project.data.year}</p>
        </div>

        <!-- Stack -->
        {project.data.stack && project.data.stack.length > 0 && (
          <div>
            <span class="text-xs font-semibold text-muted uppercase tracking-wider">Stack</span>
            <div class="flex flex-wrap gap-1.5 mt-2">
              {project.data.stack.map((item) => (
                <span class="text-xs px-2.5 py-1 bg-tag-bg border border-tag-border text-subtle rounded-full">
                  {item}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Contributions -->
        {project.data.contributions && project.data.contributions.length > 0 && (
          <div>
            <span class="text-xs font-semibold text-muted uppercase tracking-wider">Contributions</span>
            <div class="flex flex-wrap gap-1.5 mt-2">
              {project.data.contributions.map((item) => (
                <span class="text-xs px-2.5 py-1 bg-tag-bg border border-tag-border text-subtle rounded-full">
                  {item}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Links -->
        <div>
          <span class="text-xs font-semibold text-muted uppercase tracking-wider">Links</span>
          <div class="flex flex-col gap-2 mt-2">
            {project.data.liveUrl && (
              <a
                href={project.data.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2.5 bg-tag-bg border border-tag-border rounded-lg text-sm text-subtle hover:text-heading hover:border-muted transition-all duration-150"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M2 12h20"/>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
                Visit site
              </a>
            )}
            {project.data.githubUrl && (
              <a
                href={project.data.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2.5 bg-tag-bg border border-tag-border rounded-lg text-sm text-subtle hover:text-heading hover:border-muted transition-all duration-150"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/>
                </svg>
                GitHub
              </a>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Markdown content -->
    <div class="mt-12 prose prose-base max-w-none
      prose-headings:font-semibold prose-headings:tracking-tight prose-headings:text-heading
      prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3
      prose-p:leading-relaxed prose-p:text-body
      prose-a:text-accent prose-a:no-underline hover:prose-a:text-accent-hover hover:prose-a:underline
      prose-code:text-accent-hover prose-code:font-normal prose-code:bg-code-bg prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none
      prose-pre:bg-code-bg prose-pre:border prose-pre:border-border prose-pre:rounded-lg
      prose-blockquote:border-border prose-blockquote:text-subtle
      prose-hr:border-border
      prose-table:text-sm
      prose-th:text-heading prose-th:font-semibold
      prose-strong:text-heading prose-strong:font-semibold
      prose-li:text-body">
      <Content />
    </div>

    <!-- Share -->
    <div class="mt-14 pt-8 border-t border-border">
      <ShareLinks url={pageUrl} title={project.data.title} />
    </div>

  </article>
</BaseLayout>
