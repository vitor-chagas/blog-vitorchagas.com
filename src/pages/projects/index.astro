---
import BaseLayout from '../../layouts/BaseLayout.astro';

type GitHubRepo = {
  id: number;
  name: string;
  full_name: string;
  description: string | null;
  html_url: string;
  homepage: string | null;
  topics: string[];
  stargazers_count: number;
  language: string | null;
  fork: boolean;
  archived: boolean;
  updated_at: string;
};

let githubRepos: GitHubRepo[] = [];
try {
  const res = await fetch('https://api.github.com/users/vitor-chagas/repos?type=public&sort=updated&per_page=100', {
    headers: { 'Accept': 'application/vnd.github+json' },
  });
  if (res.ok) {
    const data: GitHubRepo[] = await res.json();
    githubRepos = data.filter(r => !r.fork && !r.archived);
  }
} catch (_) {}
---

<BaseLayout
  title="Projects"
  description="Tools and open-source projects I've built at the intersection of AI and video."
>
  <div class="px-8 sm:px-12 py-10">
    <div class="mb-14">
      <h1 class="text-3xl font-bold text-heading tracking-tight mb-3">Projects</h1>
      <p class="text-subtle">
        Tools I've built, mostly at the intersection of AI and video.
      </p>
    </div>

    {githubRepos.length > 0 && (
      <div>
        <div class="flex items-center justify-end mb-6">
          <a
            href="https://github.com/vitor-chagas"
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs text-muted hover:text-subtle transition-colors duration-150"
          >
            View all on GitHub ↗
          </a>
        </div>
        <ul class="divide-y divide-border">
          {githubRepos.map((repo) => (
            <li class="group py-5 first:pt-0">
              <a
                href={repo.html_url}
                target="_blank"
                rel="noopener noreferrer"
                class="block"
              >
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0">
                    <h2 class="text-base font-semibold text-heading group-hover:text-accent transition-colors duration-150">
                      {repo.name}
                    </h2>
                    {repo.description && (
                      <p class="text-sm text-subtle mt-1.5 leading-relaxed">
                        {repo.description}
                      </p>
                    )}
                    <div class="flex flex-wrap items-center gap-3 mt-2">
                      {repo.language && (
                        <span class="text-xs text-muted">{repo.language}</span>
                      )}
                      {repo.stargazers_count > 0 && (
                        <span class="text-xs text-muted">★ {repo.stargazers_count}</span>
                      )}
                      {repo.topics.slice(0, 4).map((topic) => (
                        <span class="text-xs px-2 py-0.5 bg-tag-bg border border-tag-border text-muted rounded-full">
                          {topic}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</BaseLayout>
