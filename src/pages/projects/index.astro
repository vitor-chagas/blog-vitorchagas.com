---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<BaseLayout
  title="Projects"
  description="Products, tools, and experiments I've built."
>
  <div class="px-8 sm:px-12 py-10">

    <!-- Hero -->
    <div class="flex items-start justify-between gap-8 mb-14">
      <div class="flex-1 min-w-0">
        <h1 class="text-4xl font-bold text-heading tracking-tight mb-2">
          Things I've built
        </h1>
        <p class="text-xl text-muted italic mb-6">
          Products, tools, and experiments
        </p>
        <p class="text-base text-body leading-relaxed max-w-lg">
          I like building things from the ground up. These are side
          projects, tools, and products I've shipped outside of my day job.
        </p>
      </div>
      <div class="hidden md:block shrink-0">
        <img
          src={projects[0]?.data.coverImage}
          alt=""
          class="w-64 rounded-xl border border-card-border shadow-sm"
        />
      </div>
    </div>

    <!-- Project Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>

  </div>
</BaseLayout>
