---
interface Props {
  images: string[];
}

const { images } = Astro.props;
const hasMultiple = images.length > 1;

const videoExts = ['.mp4', '.webm', '.mov'];
const isVideo = (src: string) => videoExts.some(ext => src.toLowerCase().endsWith(ext));
---

<div class="relative" data-carousel>
  <!-- Slides -->
  <div class="aspect-[16/10] bg-tag-bg rounded-xl overflow-hidden relative">
    {images.map((src, i) =>
      isVideo(src) ? (
        <video
          data-carousel-slide={i}
          src={src}
          autoplay
          muted
          loop
          playsinline
          class:list={[
            "w-full h-full object-cover absolute inset-0",
            i === 0 ? "" : "hidden",
          ]}
        />
      ) : (
        <img
          data-carousel-slide={i}
          src={src}
          alt="Project screenshot"
          class:list={[
            "w-full h-full object-cover absolute inset-0",
            i === 0 ? "" : "hidden",
          ]}
        />
      )
    )}

    <!-- Sound toggle (shown on video slides) -->
    <button
      data-carousel-sound
      class="absolute top-3 right-3 w-9 h-9 rounded-full bg-black/55 hover:bg-black/75 border-none flex items-center justify-center cursor-pointer transition-[background] duration-200 hidden"
      aria-label="Toggle sound"
    >
      <svg class="icon-muted" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
      <svg class="icon-unmuted hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
    </button>
  </div>

  {hasMultiple && (
    <!-- Navigation arrows -->
    <button
      data-carousel-prev
      class="absolute left-3 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-card/80 border border-card-border backdrop-blur-sm flex items-center justify-center text-subtle hover:text-heading transition-colors duration-150"
      aria-label="Previous image"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
    </button>
    <button
      data-carousel-next
      class="absolute right-3 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-card/80 border border-card-border backdrop-blur-sm flex items-center justify-center text-subtle hover:text-heading transition-colors duration-150"
      aria-label="Next image"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m9 18 6-6-6-6"/>
      </svg>
    </button>

    <!-- Dot indicators -->
    <div class="flex justify-center gap-2 mt-3">
      {images.map((_, i) => (
        <button
          data-carousel-dot={i}
          class:list={[
            "w-2 h-2 rounded-full transition-colors duration-150",
            i === 0 ? "bg-heading" : "bg-muted/40",
          ]}
          aria-label={`Go to image ${i + 1}`}
        />
      ))}
    </div>
  )}
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const carousel = document.querySelector('[data-carousel]');
    if (!carousel) return;

    const slides = carousel.querySelectorAll('[data-carousel-slide]');
    const soundBtn = carousel.querySelector('[data-carousel-sound]') as HTMLButtonElement | null;
    const iconMuted = soundBtn?.querySelector('.icon-muted') as HTMLElement | null;
    const iconUnmuted = soundBtn?.querySelector('.icon-unmuted') as HTMLElement | null;
    let current = 0;

    function updateSoundBtn() {
      if (!soundBtn) return;
      const slide = slides[current];
      if (slide instanceof HTMLVideoElement) {
        soundBtn.classList.remove('hidden');
        // Reset icon state to match video muted state
        if (iconMuted && iconUnmuted) {
          iconMuted.classList.toggle('hidden', !slide.muted);
          iconUnmuted.classList.toggle('hidden', slide.muted);
        }
      } else {
        soundBtn.classList.add('hidden');
      }
    }

    // Sound toggle click
    soundBtn?.addEventListener('click', () => {
      const slide = slides[current];
      if (slide instanceof HTMLVideoElement) {
        slide.muted = !slide.muted;
        if (iconMuted && iconUnmuted) {
          iconMuted.classList.toggle('hidden', !slide.muted);
          iconUnmuted.classList.toggle('hidden', slide.muted);
        }
      }
    });

    // Show sound button on initial load if first slide is a video
    updateSoundBtn();

    if (slides.length <= 1) return;

    const prevBtn = carousel.querySelector('[data-carousel-prev]');
    const nextBtn = carousel.querySelector('[data-carousel-next]');
    const dots = carousel.querySelectorAll('[data-carousel-dot]');

    function goTo(index: number) {
      const currentSlide = slides[current];
      if (currentSlide instanceof HTMLVideoElement) {
        currentSlide.pause();
      }

      current = (index + slides.length) % slides.length;

      slides.forEach((slide, i) => {
        if (i === current) {
          slide.classList.remove('hidden');
          if (slide instanceof HTMLVideoElement) {
            slide.currentTime = 0;
            slide.play();
          }
        } else {
          slide.classList.add('hidden');
        }
      });

      dots.forEach((dot, i) => {
        dot.className = dot.className.replace(/bg-heading|bg-muted\/40/g, '');
        dot.classList.add(i === current ? 'bg-heading' : 'bg-muted/40');
      });

      updateSoundBtn();
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
  });
</script>
