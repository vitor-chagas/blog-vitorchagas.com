---
---

<div class="flex flex-wrap items-center gap-x-5 gap-y-1.5 text-xs font-mono text-muted">
  <span class="flex items-center gap-1.5">
    <span id="live-dot" class="inline-block w-1.5 h-1.5 rounded-full bg-muted transition-colors duration-500"></span>
    <span class="text-muted/60 tracking-wider uppercase text-[10px]">live</span>
  </span>

  <span class="flex items-center gap-1">
    <span class="text-muted/60">BTC</span>
    <span id="btc-price">—</span>
    <span id="btc-change"></span>
  </span>

  <span class="text-border">·</span>

  <span class="flex items-center gap-1">
    <span class="text-muted/60">ETH</span>
    <span id="eth-price">—</span>
    <span id="eth-change"></span>
  </span>

  <span class="text-border">·</span>

  <span class="flex items-center gap-1">
    <span class="text-muted/60">SPX</span>
    <span id="spx-price">—</span>
    <span id="spx-change"></span>
  </span>

  <span class="text-border">·</span>

  <span class="flex items-center gap-1">
    <span class="text-muted/60">NDX</span>
    <span id="ndx-price">—</span>
    <span id="ndx-change"></span>
  </span>
</div>

<script>
  function fmt(value: number, decimals = 0) {
    return value.toLocaleString('en-US', {
      minimumFractionDigits: decimals,
      maximumFractionDigits: decimals,
    });
  }

  function setPrice(id: string, price: number) {
    const el = document.getElementById(id);
    if (el) el.textContent = `$${fmt(price)}`;
  }

  function setChange(id: string, change: number) {
    const el = document.getElementById(id);
    if (!el) return;
    const sign = change >= 0 ? '+' : '';
    el.textContent = `${sign}${change.toFixed(2)}%`;
    el.className = change >= 0 ? 'text-green-500' : 'text-red-400';
  }

  // --- Binance WebSocket: BTC + ETH ---
  const dot = document.getElementById('live-dot');

  const ws = new WebSocket(
    'wss://stream.binance.com:9443/stream?streams=btcusdt@ticker/ethusdt@ticker'
  );

  ws.onopen = () => {
    dot?.classList.replace('bg-muted', 'bg-amber-400');
    dot?.classList.add('animate-pulse');
  };

  ws.onmessage = (event) => {
    const { stream, data } = JSON.parse(event.data);
    if (stream === 'btcusdt@ticker') {
      setPrice('btc-price', parseFloat(data.c));
      setChange('btc-change', parseFloat(data.P));
    } else if (stream === 'ethusdt@ticker') {
      setPrice('eth-price', parseFloat(data.c));
      setChange('eth-change', parseFloat(data.P));
    }
  };

  ws.onerror = ws.onclose = () => {
    dot?.classList.replace('bg-amber-400', 'bg-muted');
    dot?.classList.remove('animate-pulse');
  };

  // --- Yahoo Finance polling: SPX + NDX ---
  async function fetchStocks() {
    try {
      const res = await fetch(
        'https://query1.finance.yahoo.com/v7/finance/quote?symbols=%5EGSPC,%5ENDX',
        { signal: AbortSignal.timeout(5000) }
      );
      const json = await res.json();
      const results = json.quoteResponse?.result ?? [];

      for (const item of results) {
        const price = item.regularMarketPrice;
        const change = item.regularMarketChangePercent;
        if (item.symbol === '^GSPC') {
          setPrice('spx-price', price);
          setChange('spx-change', change);
        } else if (item.symbol === '^NDX') {
          setPrice('ndx-price', price);
          setChange('ndx-change', change);
        }
      }
    } catch {
      // silent fail — dashes remain
    }
  }

  fetchStocks();
  setInterval(fetchStocks, 60_000); // refresh every minute
</script>
